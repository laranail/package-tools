{
    "name": "laranail/package-tools",
    "description": "Runtime base library for building Laravel packages — fluent Package builder + abstract PackageServiceProvider with attribute-driven discovery, package:doctor, and isolation testing.",
    "keywords": [
        "laravel",
        "package-tools",
        "laranail",
        "package-builder",
        "service-provider",
        "fluent-api"
    ],
    "homepage": "https://opensource.simtabi.com/package-tools/docs/",
    "license": "MIT",
    "authors": [
        {
            "name": "Simtabi",
            "email": "hello@simtabi.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3 || ^8.4 || ^8.5",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/filesystem": "^13.0",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^3.0",
        "phpunit/phpunit": "^11.0",
        "spatie/pest-plugin-test-time": "^2.2",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "rector/rector": "^2.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Simtabi\\Laranail\\PackageTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Simtabi\\Laranail\\PackageTools\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/fixtures/"
        ]
    },
    "scripts": {
        "setup": "bash scripts/init.sh",
        "test": "vendor/bin/pest --colors=always",
        "test-coverage": "@test --coverage",
        "test-dirty": "@test --dirty --compact",
        "lint": [
            "@pint",
            "@phpstan",
            "@rector"
        ],
        "pint": "vendor/bin/pint --test",
        "pint-fix": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan analyse --no-progress",
        "rector": "vendor/bin/rector process --dry-run",
        "rector-fix": "vendor/bin/rector process",
        "audit": [
            "@composer-audit"
        ],
        "composer-audit": "@composer audit"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "laravel": {
            "providers": [
                "Simtabi\\Laranail\\PackageTools\\Providers\\LaranailToolsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
