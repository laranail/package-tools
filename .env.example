# === Laravel framework keys (consumer fills these) ===
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# === laranail/* — dev-tool integration (all optional) ===
# Used by audit tooling that hits GitHub APIs (rate-limit relief).
LARANAIL_GITHUB_TOKEN=
# Override default log level. Values: DEBUG|INFO|WARNING|ERROR.
LARANAIL_LOG_LEVEL=INFO
